# Copy to .env for local runs, or set these in Railway → Backend service → Variables

# Local machine → use public Railway proxy
DB_HOST=tokaido.proxy.rlwy.net
DB_PORT=49551

# Backend on Railway → use private network instead:
# DB_HOST=postgres.railway.internal
# DB_PORT=5432

DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your_password_here
